# REIM Service Configuration

# Server
PORT=8000
LOG_LEVEL=INFO

# Limits
MAX_ONLINE_INSTANCES=100
MAX_BATCH_OBSERVATIONS=1000000

# CORS — comma-separated origins
CORS_ORIGINS=*

# Access Control — comma-separated list of allowed hosts
# Accepts: IPs, CIDR ranges, hostnames, domains, "docker"
#
# Development (allow all):
#   ALLOWED_HOSTS=*
#
# Docker-only (containers on same network):
#   ALLOWED_HOSTS=docker
#
# Production (your app only):
#   ALLOWED_HOSTS=docker,yourdomain.com
#
# Specific IP:
#   ALLOWED_HOSTS=93.184.216.34,172.18.0.0/16
#
ALLOWED_HOSTS=*
